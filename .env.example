# ── Database ────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://uap:changeme@localhost:5432/unifiedai

# SQLite (local dev only — no concurrency)
# DATABASE_URL=sqlite:///./automl.db

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── AI ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS (comma-separated) ───────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Storage ──────────────────────────────────────────────
STORAGE_PATH=./data_sessions
OUTPUT_PATH=./outputs

# ── Limits ───────────────────────────────────────────────
MAX_CONCURRENT_JOBS=3
MAX_FILE_SIZE_MB=200
BATCH_CHUNK_SIZE=500

# ── Drift thresholds ─────────────────────────────────────
DRIFT_THRESHOLD_PSI=0.1
DRIFT_THRESHOLD_KS=0.05

# ── PostgreSQL (docker-compose) ──────────────────────────
POSTGRES_DB=unifiedai
POSTGRES_USER=uap
POSTGRES_PASSWORD=changeme

# ── Frontend (used by docker build) ──────────────────────
REACT_APP_API_URL=http://localhost:8000
